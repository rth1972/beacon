# Optional: set a token to protect your instance
# Leave empty (or remove) for open access
NTFY_TOKEN=

# How many messages to keep per topic in history
NTFY_MAX_HISTORY=100

# Default TTL for messages in seconds (0 = never expire)
NTFY_DEFAULT_TTL=0

# Telegram bot notifications (optional)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
